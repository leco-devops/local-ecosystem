      rule: Host(`crawlervision.lh`)
      service: crawlervision-crawlervision-lh-svc
      entryPoints:
      - web
    crawlervision-crawlervision-lh-https:
      rule: Host(`crawlervision.lh`)
      service: crawlervision-crawlervision-lh-svc
      entryPoints:
      - websecure
      tls: true
    crawlervision-api-crawlervision-lh-http:
      rule: Host(`api.crawlervision.lh`)
      service: crawlervision-api-crawlervision-lh-svc
      entryPoints:
      - web
    crawlervision-api-crawlervision-lh-https:
      rule: Host(`api.crawlervision.lh`)
      service: crawlervision-api-crawlervision-lh-svc
      entryPoints:
      - websecure
      tls: true
    crawlervision-cf-kv-http:
      rule: Host(`crawlervision-kv.lh`)
      service: kv-service
      entryPoints:
      - web
    crawlervision-cf-kv-https:
      rule: Host(`crawlervision-kv.lh`)
      service: kv-service
      entryPoints:
      - websecure
      tls: true
    crawlervision-cf-r2-http:
      rule: Host(`crawlervision-r2.lh`)
      service: r2-service
      entryPoints:
      - web
    crawlervision-cf-r2-https:
      rule: Host(`crawlervision-r2.lh`)
      service: r2-service
      entryPoints:
      - websecure
      tls: true
    crawlervision-cf-d1-http:
      rule: Host(`crawlervision-d1.lh`)
      service: d1-service
      entryPoints:
      - web
    crawlervision-cf-d1-https:
      rule: Host(`crawlervision-d1.lh`)
      service: d1-service
      entryPoints:
      - websecure
      tls: true
    1note-1note-lh-http:
      rule: Host(`1note.lh`)
      service: 1note-1note-lh-svc
      entryPoints:
      - web
    1note-1note-lh-https:
      rule: Host(`1note.lh`)
      service: 1note-1note-lh-svc
