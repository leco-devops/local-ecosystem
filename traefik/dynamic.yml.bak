      - web
    1note-api-1note-lh-https:
      rule: Host(`api.1note.lh`)
      service: 1note-api-1note-lh-svc
      entryPoints:
      - websecure
      tls: true
    1note-cf-kv-http:
      rule: Host(`1note-kv.lh`)
      service: kv-service
      entryPoints:
      - web
    1note-cf-kv-https:
      rule: Host(`1note-kv.lh`)
      service: kv-service
      entryPoints:
      - websecure
      tls: true
    1note-cf-r2-http:
      rule: Host(`1note-r2.lh`)
      service: r2-service
      entryPoints:
      - web
    1note-cf-r2-https:
      rule: Host(`1note-r2.lh`)
      service: r2-service
      entryPoints:
      - websecure
      tls: true
    1note-cf-d1-http:
      rule: Host(`1note-d1.lh`)
      service: d1-service
      entryPoints:
      - web
    1note-cf-d1-https:
      rule: Host(`1note-d1.lh`)
      service: d1-service
      entryPoints:
      - websecure
      tls: true
    kanakraj-kanakraj-lh-http:
      rule: Host(`kanakraj.lh`)
      service: kanakraj-kanakraj-lh-svc
      entryPoints:
      - web
    kanakraj-kanakraj-lh-https:
      rule: Host(`kanakraj.lh`)
      service: kanakraj-kanakraj-lh-svc
      entryPoints:
      - websecure
      tls: true
    kanakraj-api-kanakraj-lh-http:
      rule: Host(`api.kanakraj.lh`)
      service: kanakraj-api-kanakraj-lh-svc
      entryPoints:
      - web
    kanakraj-api-kanakraj-lh-https:
      rule: Host(`api.kanakraj.lh`)
      service: kanakraj-api-kanakraj-lh-svc
      entryPoints:
      - websecure
      tls: true
    kanakraj-cf-kv-http:
      rule: Host(`kanakraj-kv.lh`)
      service: kv-service
      entryPoints:
      - web
    kanakraj-cf-kv-https:
      rule: Host(`kanakraj-kv.lh`)
      service: kv-service
      entryPoints:
      - websecure
      tls: true
    kanakraj-cf-r2-http:
      rule: Host(`kanakraj-r2.lh`)
      service: r2-service
      entryPoints:
      - web
    kanakraj-cf-r2-https:
      rule: Host(`kanakraj-r2.lh`)
      service: r2-service
      entryPoints:
      - websecure
      tls: true
    kanakraj-cf-d1-http:
      rule: Host(`kanakraj-d1.lh`)
      service: d1-service
      entryPoints:
