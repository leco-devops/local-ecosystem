{
  "_comment": "Cloudflare product ↔ LEco service mapping. Source of truth for docs/CF_LECO_SERVICE_MAP.md and optional dashboard panel.",
  "version": 1,
  "services": [
    {
      "cf_product": "Workers KV",
      "cf_binding": "kv_namespaces",
      "status": "implemented",
      "reuse_strategy": "extend-provision",
      "local_module": "cloudflare-local/adapters/kv-adapter",
      "compose_service": "kv-adapter",
      "backend": "valkey",
      "leco": {
        "control_id": "cf-kv-adapter",
        "hub_slug": "kv",
        "traefik_hosts": ["kv.lh"],
        "probe_url": "http://kv-adapter:8082/health",
        "provision": "local_cf_provision.kv",
        "service_map": "KV (Cloudflare local)"
      },
      "hosted_app": {
        "wrangler_table": "kv_namespaces",
        "runtime": "cloudflare-workers (Miniflare file state OR shared kv.lh)",
        "dedicated_compose": "hosting/samples/sample-cloudflare-application/docker-compose.leco-dedicated-cf.example.yml"
      }
    },
