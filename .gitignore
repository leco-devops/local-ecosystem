.DS_Store
__pycache__/
*.pyc
*.egg-info/

# Per-machine leco apps registered for LEco DevOps
config/leco-registry.yaml

# AI provider config — contains API keys, never commit
config/ai-providers.yaml
config/ui-credentials.yaml

# Per-machine hosted app manifests, overlays, and symlinks (generated by register wizard)
hosting/app-available/*/
!hosting/app-available/README.md
!hosting/app-available/.gitkeep

# Local TLS material
certs/*.pem
certs/*.key
certs/*-key.pem

# Writable runtime Traefik dynamic fragment
hosting/traefik/dynamic.yml
# Copy of traefik/dynamic.yml created by ecosystem-stack/services/traefik.sh (not a symlink)
hosting/traefik/01-stack-core.yml
# Dev-stack routes regenerated by dashboard / dev_stack_routes.py (per machine)
hosting/traefik/20-dev-stacks.yml

# Per-machine selection recorded by ecosystem-stack/install-foundation.sh
ecosystem-stack/config/install-selection.env

# Cloud VM platform config (per machine)
config/leco-platform.yaml

# Per-machine dev stacks and platform runtime (generated by dashboard; not committed)
platform/*
!platform/.gitkeep
!platform/README.md
!platform/dev-stacks/
platform/dev-stacks/*
!platform/dev-stacks/.gitkeep
!platform/dev-stacks/README.md

# Dashboard "mark updates read" state (per machine)
ecosystem-stack/config/generated/update-catalog-read-state.json

# leco-cli wrapper logs (per-run JSONL emitted by tools/leco-cli.sh)
.leco-cli-logs/

/Backup
