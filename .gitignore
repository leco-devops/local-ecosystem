.DS_Store
__pycache__/
*.pyc
*.egg-info/

# Per-machine leco apps registered for LEco DevOps
config/leco-registry.yaml

# Per-machine hosted app manifests, overlays, and symlinks (generated by register wizard)
hosting/app-available/*/
!hosting/app-available/README.md
!hosting/app-available/.gitkeep

# Local TLS material
certs/*.pem
certs/*.key
certs/*-key.pem

# Writable runtime Traefik dynamic fragment
hosting/traefik/dynamic.yml
# Copy of traefik/dynamic.yml created by ecosystem-stack/services/traefik.sh (not a symlink)
hosting/traefik/01-stack-core.yml
